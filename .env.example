NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_XXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Postgres persistence for webhook purchases.
DATABASE_URL=postgresql://user:password@localhost:5432/domain_protector

# Optional: Comma-separated proxy URLs for rotating egress.
